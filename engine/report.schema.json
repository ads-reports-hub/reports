{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Отчёт по рекламе (реальная рабочая структура, 2026-07-16)",
  "description": "Это переписанная версия схемы под структуру, которая реально используется в reports/garden-bar-june/data.json. Каждое текстовое AI-поле хранится парой _ru/_en (не единым language-переключателем), потому что готовая страница поддерживает переключение языка на клиенте. showDynamics управляет тем, показывать ли месяц-к-месяцу дельты и упоминания динамики в текстах; читается из строки клиента в таблице.",
  "type": "object",
  "required": ["client", "accountId", "period", "platform", "currency", "totals", "campaigns", "showDynamics"],
  "properties": {
    "client":    { "type": "string" },
    "accountId": { "type": "string", "description": "act_XXXXXXXXX" },
    "period":    {
      "type": "object",
      "required": ["since", "until", "label_ru", "label_en"],
      "properties": {
        "since": { "type": "string", "description": "YYYY-MM-DD" },
        "until": { "type": "string", "description": "YYYY-MM-DD" },
        "label_ru": { "type": "string", "description": "например '1 – 30 июня'" },
        "label_en": { "type": "string", "description": "например 'Jun 1 – 30'" }
      }
    },
    "prevPeriod": {
      "type": "object",
      "description": "Хранится всегда (для будущего включения динамики), даже если showDynamics=false и сейчас не отображается.",
      "properties": {
        "since": { "type": "string" },
        "until": { "type": "string" },
        "label_ru": { "type": "string" },
        "label_en": { "type": "string" }
      }
    },
    "platform": { "type": "string", "default": "Meta Ads (Instagram / Facebook)" },
    "currency": { "type": "string", "default": "Kč" },
    "source":   { "type": "string", "default": "Meta Marketing API" },
    "showDynamics": {
      "type": "boolean",
      "description": "ПО КЛИЕНТУ, читается из таблицы (колонка show_dynamics). Если false: КПИ-карточки без дельт-плашек, графики только текущего периода, тексты от ИИ не упоминают сравнение с прошлым месяцем. prevTotals в данных всё равно присутствует, просто не рендерится и не упоминается."
    },

    "totals": {
      "type": "object",
      "description": "МЕТРИКИ текущего периода. Заполняются из данных Meta API, не выдумываются.",
      "required": ["spend", "reach", "impressions", "clicks", "ctr", "cpc"],
      "properties": {
        "spend":          { "type": "number", "description": "расход, Kč" },
        "reach":          { "type": "number" },
        "impressions":    { "type": "number" },
        "frequency":      { "type": "number" },
        "clicks":         { "type": "number" },
        "ctr":            { "type": "number", "description": "%" },
        "cpc":            { "type": "number", "description": "Kč" },
        "linkClicks":     { "type": "number" },
        "postEngagement": { "type": "number" },
        "videoViews":     { "type": "number" },
        "reactions":      { "type": "number" },
        "comments":       { "type": "number" },
        "saves":          { "type": "number" }
      }
    },
    "prevTotals": {
      "type": "object",
      "description": "Метрики предыдущего периода. Хранятся всегда для будущего включения показа динамики, даже когда showDynamics=false.",
      "properties": {
        "spend": { "type": "number" }, "reach": { "type": "number" }, "impressions": { "type": "number" },
        "frequency": { "type": "number" }, "clicks": { "type": "number" }, "ctr": { "type": "number" }, "cpc": { "type": "number" }
      }
    },

    "campaigns": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "reach", "impressions", "clicks", "ctr", "cpc", "spend", "verdict_ru", "verdict_en"],
        "properties": {
          "name":           { "type": "string" },
          "date":           { "type": "string", "description": "дата запуска, например '10.06', может быть пустой строкой" },
          "goal_ru":        { "type": "string" },
          "goal_en":        { "type": "string" },
          "reach":          { "type": "number" },
          "impressions":    { "type": "number" },
          "frequency":      { "type": "number" },
          "spend":          { "type": "number" },
          "clicks":         { "type": "number" },
          "ctr":            { "type": "number" },
          "cpc":            { "type": "number" },
          "linkClicks":     { "type": "number" },
          "postEngagement": { "type": "number" },
          "videoViews":     { "type": "number" },
          "audience":       { "type": "string", "description": "человекочитаемое название таргетинга (ad set)" },
          "verdict_ru":     { "type": "string", "description": "AI-ПОЛЕ. Вывод по кампании, 1-3 предложения." },
          "verdict_en":     { "type": "string" },

          "ads": {
            "type": "array",
            "description": "Уровень объявления внутри кампании. Одна кампания может содержать 1+ объявлений на разные аудитории/креативы.",
            "items": {
              "type": "object",
              "required": ["adId", "thumb", "label_ru", "label_en", "audience_ru", "audience_en", "spend", "clicks", "ctr", "cpc"],
              "properties": {
                "adId":        { "type": "string" },
                "thumb":       { "type": "string", "description": "относительный путь, например 'assets/<adId>.jpg'" },
                "label_ru":    { "type": "string" },
                "label_en":    { "type": "string" },
                "audience_ru": { "type": "string" },
                "audience_en": { "type": "string" },
                "spend":       { "type": "number" },
                "clicks":      { "type": "number" },
                "ctr":         { "type": "number" },
                "cpc":         { "type": "number" }
              }
            }
          }
        }
      }
    },

    "audiences": {
      "type": "array",
      "description": "Сводка по уникальным таргетингам (ad set) за период, сгруппированная по названию аудитории.",
      "items": {
        "type": "object",
        "required": ["name_ru", "name_en", "spend", "reach", "ctr_range", "note_ru", "note_en"],
        "properties": {
          "name_ru": { "type": "string" }, "name_en": { "type": "string" },
          "spend": { "type": "number" }, "reach": { "type": "number" },
          "ctr_range": { "type": "string", "description": "например '1,06–1,82%' или одно значение '1,75%'" },
          "note_ru": { "type": "string", "description": "AI-ПОЛЕ" }, "note_en": { "type": "string", "description": "AI-ПОЛЕ" }
        }
      }
    },

    "platforms": {
      "type": "array",
      "description": "Разбивка по площадкам/позициям (Facebook лента, Instagram Stories, Reels и т.д.).",
      "items": {
        "type": "object",
        "required": ["key", "label_ru", "label_en", "reach", "spend", "clicks", "cpc"],
        "properties": {
          "key": { "type": "string", "description": "например facebook_feed, instagram_reels" },
          "label_ru": { "type": "string" }, "label_en": { "type": "string" },
          "reach": { "type": "number" }, "spend": { "type": "number" }, "clicks": { "type": "number" }, "cpc": { "type": "number" }
        }
      }
    },

    "demographics": {
      "type": "object",
      "required": ["note_ru", "note_en", "rows"],
      "properties": {
        "note_ru": { "type": "string", "description": "AI-ПОЛЕ" },
        "note_en": { "type": "string", "description": "AI-ПОЛЕ" },
        "rows": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["gender", "age", "reach", "spend", "ctr"],
            "properties": {
              "gender": { "type": "string", "enum": ["male", "female"] },
              "age":    { "type": "string", "description": "например '25-34', '65+'" },
              "reach":  { "type": "number" }, "spend": { "type": "number" }, "ctr": { "type": "number" }
            }
          }
        }
      }
    },

    "topAds": {
      "type": "array",
      "description": "Подборка 2-3 лучших объявлений за период по всем кампаниям, для отдельного блока 'Лучшие объявления'.",
      "items": {
        "type": "object",
        "required": ["adId", "thumb", "name_ru", "name_en", "badge_ru", "badge_en", "metric_ru", "metric_en", "reason_ru", "reason_en", "best"],
        "properties": {
          "adId": { "type": "string" }, "thumb": { "type": "string" },
          "name_ru": { "type": "string" }, "name_en": { "type": "string" },
          "badge_ru": { "type": "string" }, "badge_en": { "type": "string" },
          "metric_ru": { "type": "string" }, "metric_en": { "type": "string" },
          "reason_ru": { "type": "string", "description": "AI-ПОЛЕ" }, "reason_en": { "type": "string", "description": "AI-ПОЛЕ" },
          "best": { "type": "boolean", "description": "true у ровно одной записи, отмечает главный 'Лучший отклик'" }
        }
      }
    },

    "findings_ru":        { "type": "array", "items": { "type": "string" }, "description": "AI-ПОЛЕ. 4-6 пунктов." },
    "findings_en":        { "type": "array", "items": { "type": "string" } },
    "recommendations_ru": { "type": "array", "items": { "type": "string" }, "description": "AI-ПОЛЕ. 4-6 пунктов." },
    "recommendations_en": { "type": "array", "items": { "type": "string" } },

    "euNote_ru": { "type": "string", "description": "Фиксированный дисклеймер про переписки в директ в кабинетах ЕС. Не AI-поле, статичный текст." },
    "euNote_en": { "type": "string" },

    "meta": {
      "type": "object",
      "properties": {
        "generatedAt": { "type": "string", "description": "ISO 8601, момент генерации отчёта" },
        "generatedBy": { "type": "string", "enum": ["automation", "manual"], "description": "кто сгенерировал: автоматика или ручной прогон" }
      }
    }
  }
}
